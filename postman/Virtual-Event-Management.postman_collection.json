{
  "info": {
    "_postman_id": "virtual-event-management-api",
    "name": "Virtual Event Management API",
    "description": "Complete Postman collection for testing the Virtual Event Management backend.\n\n## Quick start\n1. Import this collection and the environment file (`Virtual-Event-Management.postman_environment.json`).\n2. Start the server: `npm run dev`\n3. Run **Health Check** to verify the server is running.\n4. Run **Register Organizer** and **Register Attendee**.\n5. Run **Login Organizer** — tokens are saved automatically to collection variables.\n6. Run **Create Event**, then **Login Attendee** and **Register for Event**.\n\n## Variables (auto-set)\n- `accessToken` — set after Login / Refresh\n- `refreshToken` — set after Login / Refresh\n- `eventId` — set after Create Event",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "eventId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public endpoint. Verifies the API server is running.\n\n**Expected:** `200 OK`"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Organizer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Organizer\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"organizer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "description": "Register a new user with **organizer** role.\n\n**Required fields:** name, email, password, role\n\n**Expected:** `201 Created`"
          },
          "response": []
        },
        {
          "name": "Register Attendee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Attendee\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"attendee\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "description": "Register a new user with **attendee** role.\n\n**Expected:** `201 Created`"
          },
          "response": []
        },
        {
          "name": "Login Organizer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    console.log('Tokens saved to collection variables');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Login as organizer. **Automatically saves** `accessToken` and `refreshToken` to collection variables.\n\n**Expected:** `200 OK` with token pair"
          },
          "response": []
        },
        {
          "name": "Login Attendee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    console.log('Tokens saved to collection variables');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Login as attendee. **Automatically saves** tokens to collection variables.\n\n**Expected:** `200 OK`"
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    console.log('New tokens saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["refresh"]
            },
            "description": "Exchange refresh token for a new access + refresh token pair. Old refresh token is revoked.\n\n**Expected:** `200 OK`"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/logout",
              "host": ["{{baseUrl}}"],
              "path": ["logout"]
            },
            "description": "Revoke both access and refresh tokens. Requires valid access token in Authorization header.\n\n**Expected:** `200 OK`"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List All Events",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Get all events. Requires authentication (any role).\n\n**Expected:** `200 OK` with events array"
          },
          "response": []
        },
        {
          "name": "Get Event by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Get a single event by ID. Requires authentication.\n\n**Expected:** `200 OK` or `404 Not Found`"
          },
          "response": []
        },
        {
          "name": "Create Event (Organizer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('eventId', json.data.id);",
                  "    console.log('eventId saved:', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"AI Summit 2026\",\n  \"date\": \"2026-07-15\",\n  \"time\": \"10:00\",\n  \"description\": \"Virtual AI conference with industry leaders and workshops\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Create a new event. **Organizer role required.**\n\nRun **Login Organizer** first.\n\n**Date format:** YYYY-MM-DD\n**Time format:** HH:MM (24-hour)\n\n**Expected:** `201 Created` — eventId saved automatically"
          },
          "response": []
        },
        {
          "name": "Update Event (Organizer)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"AI Summit 2026 - Updated\",\n  \"description\": \"Updated description with new speakers\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Update an event. **Organizer only** — must be the event creator.\n\nAt least one field required: title, date, time, description.\n\n**Expected:** `200 OK`"
          },
          "response": []
        },
        {
          "name": "Delete Event (Organizer)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}"]
            },
            "description": "Delete an event. **Organizer only** — must be the event creator.\n\n**Expected:** `200 OK`"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Participants",
      "item": [
        {
          "name": "Register for Event (Attendee)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "register"]
            },
            "description": "Register for an event. **Attendee role required.**\n\nRun **Login Attendee** first. A confirmation email is sent (or logged to console).\n\n**Expected:** `200 OK`"
          },
          "response": []
        },
        {
          "name": "Get My Registrations (Attendee)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/my/registrations",
              "host": ["{{baseUrl}}"],
              "path": ["events", "my", "registrations"]
            },
            "description": "View all events the logged-in attendee has registered for.\n\n**Attendee role required.**\n\n**Expected:** `200 OK`"
          },
          "response": []
        },
        {
          "name": "Cancel Registration (Attendee)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/{{eventId}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["events", "{{eventId}}", "register"]
            },
            "description": "Cancel registration for an event. **Attendee role required.**\n\n**Expected:** `200 OK`"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases (Examples)",
      "item": [
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "**Expected:** `401 Unauthorized`"
          },
          "response": []
        },
        {
          "name": "Create Event - Attendee Forbidden",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Blocked Event\",\n  \"date\": \"2026-08-01\",\n  \"time\": \"10:00\",\n  \"description\": \"Should fail with 403\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Run **Login Attendee** first. Attendees cannot create events.\n\n**Expected:** `403 Forbidden`"
          },
          "response": []
        },
        {
          "name": "Get Events - No Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Request without Authorization header.\n\n**Expected:** `401 Unauthorized`"
          },
          "response": []
        },
        {
          "name": "Register - Duplicate Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Again\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"organizer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "description": "Register with an email that already exists.\n\n**Expected:** `409 Conflict`"
          },
          "response": []
        },
        {
          "name": "Get Event - Not Found",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/events/9999",
              "host": ["{{baseUrl}}"],
              "path": ["events", "9999"]
            },
            "description": "**Expected:** `404 Not Found`"
          },
          "response": []
        }
      ]
    }
  ]
}
